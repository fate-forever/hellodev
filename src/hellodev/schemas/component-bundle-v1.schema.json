{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fate-forever/hellodev/schemas/component-bundle-v1.schema.json",
  "title": "HelloDev component bundle manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "distributionVersion", "target", "controlledRoots", "distributionFiles", "components"],
  "properties": {
    "schemaVersion": {"const": 1},
    "distributionVersion": {"const": "0.14.1"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture"],
      "properties": {
        "os": {"enum": ["windows", "linux", "macos"]},
        "architecture": {"enum": ["x86_64", "arm64"]}
      }
    },
    "controlledRoots": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "distributionFiles": {"$ref": "#/$defs/files"},
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trellis", "nocturne"],
      "properties": {
        "trellis": {"$ref": "#/$defs/component"},
        "nocturne": {"$ref": "#/$defs/component"}
      }
    }
  },
  "$defs": {
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 512},
          "size": {"type": "integer", "minimum": 0, "maximum": 2147483648},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "revision", "repository", "licenseSpdx", "command", "args", "cwd", "dataPolicy", "environment", "identityFiles", "controlledRoots", "files"],
      "properties": {
        "version": {"type": "string", "minLength": 1, "maxLength": 256},
        "revision": {"type": "string", "minLength": 1, "maxLength": 256},
        "repository": {"type": "string", "minLength": 1, "maxLength": 256},
        "licenseSpdx": {"type": "string", "minLength": 1, "maxLength": 64},
        "command": {"type": "string", "minLength": 1, "maxLength": 512},
        "args": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 1024}},
        "cwd": {"type": ["string", "null"], "maxLength": 512},
        "dataPolicy": {"enum": ["none", "separate-user-data"]},
        "environment": {
          "type": "object",
          "maxProperties": 16,
          "propertyNames": {"pattern": "^[A-Z][A-Z0-9_]{0,63}$"},
          "additionalProperties": {"type": "string", "maxLength": 1024}
        },
        "identityFiles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "controlledRoots": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "files": {"$ref": "#/$defs/files"}
      }
    }
  }
}
