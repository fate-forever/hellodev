{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fate-forever/hellodev/schema/host-protocol-v1.json",
  "title": "HelloDev Host Protocol Negotiation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestedVersions"],
  "properties": {
    "requestedVersions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}
    }
  }
}
